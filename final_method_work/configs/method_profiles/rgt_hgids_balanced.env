# RGT-HGIDS recommended paper experiment profile
RIGOR_LEVEL=balanced
CADETS_EA_PRESET=calib8m
SEEDS="42 43 44"
EPOCHS=8
VAL_EVERY=1
RUN_DATASETS="cadets theia"
RUN_ENCODERS="mcbg rgd_bigru"
REDUNDANCY_MODE=target_boundary
TBB_RR_TARGET_COMPRESSION=0.90
RGD_KERNEL_SIZE=3
RGD_DILATIONS=1,2
RGD_DROPOUT=0.2
RGD_RESIDUAL_SCALE_INIT=0.1
RGD_DEPTHWISE_SEPARABLE=1
RGD_USE_EVENT_WEIGHT_POOLING=1
MODEL_SELECTION_METRIC=val_average_precision
THRESHOLD_STRATEGY=val_f1_min_recall
THRESHOLD_MIN_RECALL=0.95
